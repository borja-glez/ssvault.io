---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { siteConfig, toAbsoluteSiteUrl } from '../shared/config/site';
import { getTranslations } from '../shared/i18n';
import type { Locale } from '../shared/i18n';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  robots?: string;
  ogImagePath?: string;
}

const locale = Astro.locals.locale as Locale;
const t = getTranslations(locale);

const {
  title = siteConfig.title,
  description = siteConfig.description,
  canonicalPath = Astro.url.pathname || siteConfig.defaultCanonicalPath,
  robots = siteConfig.robots,
  ogImagePath = siteConfig.defaultOgImagePath,
} = Astro.props;

const canonicalUrl = toAbsoluteSiteUrl(canonicalPath);
const ogImageUrl = toAbsoluteSiteUrl(ogImagePath);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href={siteConfig.manifestPath} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content={siteConfig.themeColor} />
    <meta name="application-name" content={siteConfig.name} />
    <meta name="apple-mobile-web-app-title" content={siteConfig.name} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta
      property="og:image:alt"
      content="ssvault Lite, derivación local de credenciales con Argon2id + HKDF"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col">
    <div class="bg-ambient" aria-hidden="true"></div>
    <Header locale={locale} t={t} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer t={t} />
  </body>
</html>
